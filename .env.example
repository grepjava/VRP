# ── Map ───────────────────────────────────────────────────────────────────────
# Browse regions at: https://download.geofabrik.de/
# Examples:
#   Asia:   https://download.geofabrik.de/asia/malaysia-singapore-brunei-latest.osm.pbf
#   Europe: https://download.geofabrik.de/europe/germany-latest.osm.pbf
#   US:     https://download.geofabrik.de/north-america/us/california-latest.osm.pbf
MAP_URL=https://download.geofabrik.de/asia/malaysia-singapore-brunei-latest.osm.pbf
MAP_FILE=malaysia-singapore-brunei-latest.osm.pbf
OSRM_FILE=malaysia-singapore-brunei-latest.osrm

# ── Ports ─────────────────────────────────────────────────────────────────────
UI_PORT=80
API_PORT=8000

# ── GPU Memory Pool ───────────────────────────────────────────────────────────
# Sizes in bytes. Tune to your GPU's VRAM.
# 1 GB = 1073741824   |   4 GB = 4294967296   |   8 GB = 8589934592
GPU_MEMORY_INITIAL=1073741824
GPU_MEMORY_MAX=8589934592

# ── Concurrent Solvers ────────────────────────────────────────────────────────
# Number of parallel cuOpt instances. Each uses CUOPT_MEMORY_PER_INSTANCE MB.
# Rule of thumb: GPU_MEMORY_MAX / CUOPT_MEMORY_PER_INSTANCE
CUOPT_CONCURRENT_INSTANCES=4
CUOPT_MEMORY_PER_INSTANCE=1024
